generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SearchSource {
  GOOGLE
  MAPS
  DIRECTORY
}

enum SearchRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  searches      SavedSearch[]
  jobRuns       JobRun[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model SavedSearch {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  keyword    String
  location   String
  source     SearchSource
  cursorPage Int?          @map("cursor_page")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  caches     SearchPageCache[]
  leads      Lead[]
  runs       SearchRun[]

  @@index([userId])
}

model SearchRun {
  id         String          @id @default(cuid())
  searchId   String          @map("search_id")
  status     SearchRunStatus
  startedAt  DateTime?       @map("started_at")
  finishedAt DateTime?       @map("finished_at")
  error      String?
  jobId      String?         @map("job_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  search     SavedSearch     @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([searchId])
  @@index([searchId, status])
}

model SearchPageCache {
  id         String      @id @default(cuid())
  searchId   String      @map("search_id")
  userId     String      @map("user_id")
  pageIndex  Int         @map("page_index")
  rawPayload Json        @map("raw_payload")
  createdAt  DateTime    @default(now()) @map("created_at")
  search     SavedSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@unique([searchId, pageIndex])
  @@index([userId])
}

model Lead {
  id        String      @id @default(cuid())
  searchId  String      @map("search_id")
  userId    String      @map("user_id")
  url       String
  title     String?
  createdAt DateTime    @default(now()) @map("created_at")
  search    SavedSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  analysis  Analysis?

  @@unique([searchId, url])
  @@index([searchId])
  @@index([userId])
}

model Analysis {
  id                  String   @id @default(cuid())
  leadId              String   @unique @map("lead_id")
  userId              String   @map("user_id")
  scrapedPayload      Json     @map("scraped_payload")
  rawMetrics          Json     @map("raw_metrics")
  categoryScores      Json     @map("category_scores")
  checks              Json     @map("checks")
  avgScore            Float?   @map("avg_score")
  isUnderperforming   Boolean  @default(false) @map("is_underperforming")
  createdAt           DateTime @default(now()) @map("created_at")
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isUnderperforming])
}

model JobRun {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  kind      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum SearchPipelineStatus {
  PROCESSING
  READY
  FAILED
}

enum ContactType {
  EMAIL
  PHONE
  WHATSAPP
}

model Search {
  id            String               @id @default(cuid())
  hash          String               @unique
  keyword       String
  area          String
  country       String?
  platform      String
  intent        String?
  status        SearchPipelineStatus @default(PROCESSING)
  error         String?
  createdAt     DateTime             @default(now()) @map("created_at")
  lastFetchedAt DateTime?            @map("last_fetched_at")
  results       SearchResult[]

  @@index([createdAt])
  @@index([lastFetchedAt])
}

model SearchResult {
  id        String   @id @default(cuid())
  searchId  String   @map("search_id")
  title     String
  link      String
  snippet   String
  position  Int
  domainId  String   @map("domain_id")
  createdAt DateTime @default(now()) @map("created_at")
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  search    Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@unique([searchId, link])
  @@index([searchId, position])
  @@index([domainId])
}

model Domain {
  id            String         @id @default(cuid())
  domain        String         @unique
  rootDomain    String         @map("root_domain")
  firstSeenAt   DateTime       @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime       @default(now()) @map("last_seen_at")
  categories    Json?
  locations     Json?
  business      Business?
  searchResults SearchResult[]

  @@index([rootDomain])
  @@index([lastSeenAt])
}

model Business {
  id              String          @id @default(cuid())
  name            String
  domainId        String          @unique @map("domain_id")
  category        String?
  location        String?
  confidenceScore Int             @default(0) @map("confidence_score")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  contacts        Contact[]
  domain          Domain          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  socialProfiles  SocialProfile[]

  @@index([confidenceScore])
}

model Contact {
  id         String      @id @default(cuid())
  businessId String      @map("business_id")
  type       ContactType
  value      String
  source     String
  createdAt  DateTime    @default(now()) @map("created_at")
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type, value])
  @@index([businessId])
}

model SocialProfile {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  platform   String
  url        String
  createdAt  DateTime @default(now()) @map("created_at")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, url])
  @@index([businessId])
}
