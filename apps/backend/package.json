{
  "name": "@fixlytics/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm run dev:compile-once && concurrently -k -n compile,api -c cyan,green \"pnpm run dev:compile\" \"pnpm run dev:serve\"",
    "dev:compile-once": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev:compile": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "dev:serve": "nodemon",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
