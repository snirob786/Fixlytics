PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/fixlytics
REDIS_URL=redis://localhost:6379
# When unset/false/0/no, Bull/Redis is off: searches use Postgres only; POST …/searches/:id/run returns 503.
# Set to true/1/yes when REDIS_URL is available to enable the job queue.
USE_JOB_QUEUE=
# fixture (default) uses deterministic in-process data; http is reserved for allowlisted fetches.
SCRAPER_MODE=fixture
FRONTEND_ORIGIN=http://localhost:3000
# Auth uses HttpOnly cookies (fixlytics_access, fixlytics_refresh); keep FRONTEND_ORIGIN aligned with the Next.js origin.
# Required in production (min 32 characters). Omitted in development uses a dev-only default.
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
SMARTLEAD_API_KEY=
OPENAI_API_KEY=

# Optional — `pnpm db:seed` (defaults below if unset)
# SEED_USER_EMAIL=dev@fixlytics.local
# SEED_USER_PASSWORD=devpassword12
